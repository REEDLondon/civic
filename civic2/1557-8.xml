      <body>
         <div type="record_set">
            <div type="record" source="#bakers">
               <head>
                  <title>Bakers’ Company Audit Book, 1548-1586</title>
                  <bibl source="#london-metropolitan-archives">LMA:
                     CLC/L/BA/D/001/MS05174/002</bibl>
                  <supplied>(1557-8) (Payments)</supplied>
               </head>
               <pb type="folio" n="72v"/>
               <gap/>
               <note type="marginal" place="margin_left">for ij xvtenes for ye Citie for and agenst
                  the Coronacon of quene Elizabeth</note>
               <table>
                  <row>
                     <cell role="label">Paide in december to Thandes [sic] of Thomas
                        Will<ex>ia</ex>mson and Thom<ex>a</ex>s Stainer Collectorrs for ij xvtenes
                        for the furnyture of pageant<ex>es</ex> agenst the Coronacon of quene
                        Elizabeth</cell>
                     <cell role="data">xiij s. iiij d.</cell>
                  </row>
               </table>
            </div>
            <div type="record" source="#carpenters">
               <head>
                  <title>Carpenters’ Company Wardens’ Accounts, 1546-1573</title>
                  <bibl source="#london-metropolitan-archives">LMA:
                     CLC/L/CC/D/002/MS04326/002</bibl>
                  <supplied>15th August 1557-15th August 1558</supplied>
               </head>
               <pb type="page" n="151"/>
               <label>(Payments)</label>
               <gap/>
               <table>
                  <row>
                     <cell role="label">It<ex>e</ex>m payd for a barge to Westmyster to Wayt Apon my
                        lord Mayor</cell>
                     <cell role="data">xiij s. iiij d.</cell>
                  </row>
                  <row>
                     <cell role="label">It<ex>e</ex>m payd for ij burdyn of Russhes for the
                        barge</cell>
                     <cell role="data">vj d.</cell>
                  </row>
               </table>
               <gap/>
               <pb type="page" n="157"/>
               <label>(Payments)</label>
               <p>the dynner daye</p>
               <gap/>
               <table>
                  <row>
                     <cell role="label">It<ex>e</ex>m payd to the mynstrell<ex>es</ex>for ther
                           attendanc<ex>e</ex></cell>
                     <cell role="data">iij s. iiij d.</cell>
                  </row>
               </table>
            </div>
         </div>
